# ── Service Accounts ─────────────────────────────────────────────────────────

dn: uid=svc-keycloak,ou=service-accounts,dc=rbclab,dc=local
objectClass: inetOrgPerson
uid: svc-keycloak
cn: Keycloak Service Account
sn: ServiceAccount
mail: svc-keycloak@rbclab.local
description: Read-only bind account for Keycloak LDAP federation
