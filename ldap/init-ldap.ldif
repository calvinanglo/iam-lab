# init-ldap.ldif
# Bootstrap LDAP directory with OU structure and sample users
# Apply with: ldapadd -x -H ldap://localhost:389 -D "cn=admin,dc=rbclab,dc=local" -W -f init-ldap.ldif

# Organizational Units
dn: ou=users,dc=rbclab,dc=local
objectClass: organizationalUnit
ou: users

dn: ou=groups,dc=rbclab,dc=local
objectClass: organizationalUnit
ou: groups

dn: ou=service-accounts,dc=rbclab,dc=local
objectClass: organizationalUnit
ou: service-accounts

# ── Groups ──────────────────────────────────────────────────────────────────

dn: cn=traders,ou=groups,dc=rbclab,dc=local
objectClass: groupOfNames
cn: traders
member: uid=jsmith,ou=users,dc=rbclab,dc=local

dn: cn=risk-analysts,ou=groups,dc=rbclab,dc=local
objectClass: groupOfNames
cn: risk-analysts
member: uid=alee,ou=users,dc=rbclab,dc=local

dn: cn=compliance-admins,ou=groups,dc=rbclab,dc=local
objectClass: groupOfNames
cn: compliance-admins
member: uid=mchen,ou=users,dc=rbclab,dc=local

dn: cn=helpdesk,ou=groups,dc=rbclab,dc=local
objectClass: groupOfNames
cn: helpdesk
member: uid=bpatel,ou=users,dc=rbclab,dc=local

dn: cn=iam-admins,ou=groups,dc=rbclab,dc=local
objectClass: groupOfNames
cn: iam-admins
member: uid=svc-iam,ou=service-accounts,dc=rbclab,dc=local

# ── Sample Users ─────────────────────────────────────────────────────────────
# Passwords set to "ChangeMe123!" — users must change on first login via KC Required Action
# To regenerate: slappasswd -s "YourPassword"
# The SSHA hash below corresponds to "ChangeMe123!" and is safe for lab bootstrap only

dn: uid=jsmith,ou=users,dc=rbclab,dc=local
objectClass: inetOrgPerson
objectClass: posixAccount
uid: jsmith
cn: John Smith
sn: Smith
givenName: John
mail: jsmith@rbclab.local
ou: Trading
title: Senior Trader
uidNumber: 1001
gidNumber: 1001
homeDirectory: /home/jsmith
userPassword: {SSHA}BOOTSTRAP_HASH
loginShell: /bin/bash

