# ══════════════════════════════════════════════════════════════════════════════
# IAM Lab — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and replace all CHANGE_ME values before starting.
#   cp .env.example .env
#
# NEVER commit .env to git. It is excluded via .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ── Keycloak ──────────────────────────────────────────────────────────────────
KC_HOSTNAME=keycloak.iam-lab.local
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_bootstrap_admin

# Permanent admin account (created after bootstrap admin is deleted)
KEYCLOAK_SUPERADMIN_USER=iam-superadmin
KEYCLOAK_SUPERADMIN_PASSWORD=CHANGE_ME_superadmin

# ── PostgreSQL (Keycloak backend) ─────────────────────────────────────────────
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=CHANGE_ME_postgres
KC_DB_PASSWORD=CHANGE_ME_postgres
POSTGRES_MAX_CONNECTIONS=100

# ── OpenLDAP ──────────────────────────────────────────────────────────────────
LDAP_ORGANISATION=IAM Lab
LDAP_DOMAIN=rbclab.local
LDAP_ADMIN_PASSWORD=CHANGE_ME_ldap_admin
LDAP_CONFIG_PASSWORD=CHANGE_ME_ldap_config
LDAP_READONLY_USER_PASSWORD=CHANGE_ME_ldap_readonly

# Default password for bootstrapped LDAP users (they must change on first login)
LDAP_USER_DEFAULT_PASSWORD=ChangeMe123!

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_admin
GF_SECURITY_SECRET_KEY=CHANGE_ME_min_32_chars_random_string
GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET=CHANGE_ME_grafana_oauth_secret

# ── Nextcloud ─────────────────────────────────────────────────────────────────
NEXTCLOUD_ADMIN_USER=ncadmin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_nextcloud_admin

# ── Gitea ─────────────────────────────────────────────────────────────────────
GITEA_OAUTH_CLIENT_SECRET=CHANGE_ME_gitea_oauth_secret
GITEA_ADMIN_USER=gitea-admin
GITEA_ADMIN_PASSWORD=CHANGE_ME_gitea_admin
